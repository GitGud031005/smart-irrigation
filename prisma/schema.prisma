// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String  @id @default(uuid()) @map("user_id")
  email            String  @unique
  passwordHash     String  @map("password_hash")
  adafruitUsername String  @default("") @map("adafruit_username")
  adafruitKey      String  @default("") @map("adafruit_key")

  zones    Zone[]
  profiles IrrigationProfile[]
  schedules Schedule[]

  @@map("USER")
}

model IrrigationProfile {
  id              String @id @default(uuid()) @map("profile_id")
  name            String?
  minMoisture     Float  @map("min_moisture")
  maxMoisture     Float  @map("max_moisture")
  mode            IrrigationMode @default(AUTO) @map("mode")

  user   User?  @relation(fields: [userId], references: [id])
  userId String? @map("user_id")

  zones Zone[]

  @@map("IRRIGATION_PROFILE")
}

model Schedule {
  id        String     @id @default(uuid()) @map("schedule_id")
  name      String

  user   User?  @relation(fields: [userId], references: [id])
  userId String? @map("user_id")

  timeSlots TimeSlot[]
  zone      Zone?

  @@map("SCHEDULE")
}

model TimeSlot {
  id         String   @id @default(uuid()) @map("timeslot_id")
  startTime  String   @map("start_time")    // "HH:MM"
  days       String[]                       // ["Monday","Tuesday",...]
  duration   Int                            // seconds

  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  scheduleId String   @map("schedule_id")

  @@map("TIME_SLOT")
}

model Zone {
  id                 String  @id @default(uuid()) @map("zone_id")
  name               String

  user   User? @relation(fields: [userId], references: [id])
  userId String?

  profile   IrrigationProfile? @relation(fields: [profileId], references: [id])
  profileId String?

  schedule   Schedule? @relation(fields: [scheduleId], references: [id])
  scheduleId String? @unique

  devices Device[]
  sensorReadings SensorReading[]
  irrigationEvents IrrigationEvent[]
  alerts Alert[]

  @@map("ZONE")
}

model Device {
  id         String      @id @default(uuid()) @map("device_id")
  deviceType DeviceType? @map("device_type")
  feedKey    String?     @map("feed_key")

  zone   Zone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  zoneId String

  lastActiveAt DateTime?    @map("last_active_at")
  status       DeviceStatus @default(ACTIVE) @map("status")

  @@map("DEVICE")
}

enum DeviceType {
  SOIL_MOISTURE_SENSOR
  DHT20_TEMPERATURE_SENSOR
  DHT20_HUMIDITY_SENSOR
  RELAY_MODULE
  ESP32
}

enum IrrigationMode {
  AUTO
  MANUAL
  AI
}

enum DeviceStatus {
  ACTIVE
  OFFLINE
  ERROR
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertType {
  DEVICE_STATUS
  PLANT_STATUS
  IRRIGATION_EVENT
}

enum AlertActor {
  USER
  SYSTEM
  AI
}

model SensorReading {
  id          String   @id @default(uuid()) @map("reading_id")
  
  zone        Zone?    @relation(fields: [zoneId], references: [id])
  zoneId      String?  @map("zone_id")
  
  soilMoisture Float?  @map("soil_moisture")
  temperature  Float?
  humidity     Float?
  
  recordedAt   DateTime @default(now()) @map("recorded_at")

  @@map("SENSOR_READING")
}

model IrrigationEvent {
  id          String   @id @default(uuid()) @map("event_id")
  zone        Zone?    @relation(fields: [zoneId], references: [id])
  zoneId      String?
  startTime   DateTime @map("start_time")
  endTime     DateTime? @map("end_time")
  duration    Int?

  @@map("IRRIGATION_EVENT")
}

model Alert {
  id        String        @id @default(uuid()) @map("alert_id")
  zone      Zone?         @relation(fields: [zoneId], references: [id])
  zoneId    String?
  message   String
  severity  AlertSeverity @default(INFO)     @map("severity")
  type      AlertType                        @map("type")
  actor     AlertActor                       @map("actor")
  createdAt DateTime      @default(now())    @map("created_at")

  @@map("ALERT")
}
