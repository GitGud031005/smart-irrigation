// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id @default(uuid()) @map("user_id")
  email        String  @unique
  passwordHash String  @map("password_hash")

  zones Zone[]

  @@map("USER")
}

model IrrigationProfile {
  id              String @id @default(uuid()) @map("profile_id")
  name            String?
  minMoisture     Float  @map("min_moisture")
  maxMoisture     Float  @map("max_moisture")
  mode            IrrigationMode @default(AUTO) @map("mode")

  zones Zone[]

  @@map("IRRIGATION_PROFILE")
}

model Schedule {
  id             String  @id @default(uuid()) @map("schedule_id")
  cronExpression String  @map("cron_expression")
  isActive       Boolean @default(true) @map("is_active")

  zone Zone?

  @@map("SCHEDULE")
}

model Zone {
  id                 String  @id @default(uuid()) @map("zone_id")
  name               String

  user   User? @relation(fields: [userId], references: [id])
  userId String?

  profile   IrrigationProfile? @relation(fields: [profileId], references: [id])
  profileId String?

  schedule   Schedule? @relation(fields: [scheduleId], references: [id])
  scheduleId String? @unique

  currentMoisture   Float @default(0) @map("current_moisture")
  currentHumidity   Float @default(0) @map("current_humidity")
  currentTemperature Float @default(0) @map("current_temperature")

  devices Device[]
  irrigationEvents IrrigationEvent[]
  alerts Alert[]

  @@map("ZONE")
}

model Device {
  id         String @id @default(uuid()) @map("device_id")
  deviceType String? @map("device_type")

  zone   Zone? @relation(fields: [zoneId], references: [id])
  zoneId String?

  lastActiveAt DateTime? @map("last_active_at")
  status       DeviceStatus @default(ACTIVE) @map("status")

  soilMoistureReadings SensorReading[] @relation("soilMoistureSensor")
  temperatureReadings SensorReading[] @relation("temperatureSensor")
  humidityReadings SensorReading[] @relation("humiditySensor")

  @@map("DEVICE")
}

enum IrrigationMode {
  AUTO
  MANUAL
  AI
}

enum DeviceStatus {
  ACTIVE
  OFFLINE
  ERROR
}

model SensorReading {
  id          String   @id @default(uuid()) @map("reading_id")
  
  soilMoistureSensor   Device?  @relation("soilMoistureSensor", fields: [soilMoistureSensorId], references: [id])
  soilMoistureSensorId String?  @map("soil_moisture_sensor_id")
  soilMoisture         Float?   @map("soil_moisture")
  
  temperatureSensor    Device?  @relation("temperatureSensor", fields: [temperatureSensorId], references: [id])
  temperatureSensorId  String?  @map("temperature_sensor_id")
  temperature          Float?
  
  humiditySensor       Device?  @relation("humiditySensor", fields: [humiditySensorId], references: [id])
  humiditySensorId     String?  @map("humidity_sensor_id")
  humidity             Float?
  
  recordedAt   DateTime @default(now()) @map("recorded_at")

  @@map("SENSOR_READING")
}

model IrrigationEvent {
  id          String   @id @default(uuid()) @map("event_id")
  zone        Zone?    @relation(fields: [zoneId], references: [id])
  zoneId      String?
  startTime   DateTime @map("start_time")
  endTime     DateTime? @map("end_time")
  duration    Int?

  @@map("IRRIGATION_EVENT")
}

model Alert {
  id        String   @id @default(uuid()) @map("alert_id")
  zone      Zone?    @relation(fields: [zoneId], references: [id])
  zoneId    String?
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ALERT")
}
